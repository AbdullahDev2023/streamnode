# AuraCast Server — Environment Configuration
# Copy this file to .env and fill in your values.
# .env is already in .gitignore — never commit secrets.

# ── Networking ────────────────────────────────────────────────────────────────
PORT=4000

# ── Firebase ──────────────────────────────────────────────────────────────────
FIREBASE_DB_URL=https://auracast-df815-default-rtdb.asia-southeast1.firebasedatabase.app
FIREBASE_DB_SECRET=

# ── WebSocket tuning ──────────────────────────────────────────────────────────
WS_PING_INTERVAL_MS=30000
STALE_THRESHOLD_MS=90000
STALE_CHECK_MS=15000
STATS_INTERVAL_MS=2000

# ── Channel lifecycle ─────────────────────────────────────────────────────────
CHANNEL_GRACE_MS=300000

# ── Audio ─────────────────────────────────────────────────────────────────────
SERVER_VOLUME_GAIN=3.0

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO

# ── Rate limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_ENABLED=false
MAX_REQUESTS_PER_WINDOW=120
RATE_WINDOW_MS=60000

# ── WebRTC / STUN ─────────────────────────────────────────────────────────────
# AuraCast is STUN-only.  TURN is permanently disabled.
#
# How NAT traversal works in AuraCast:
#   • ~80-85 % of networks  →  STUN succeeds  →  WebRTC P2P (⚡ direct, lowest latency)
#   • Symmetric NAT / UDP-blocked networks  →  ICE FAILED
#                           →  ConnectionOrchestrator activates WS relay (<50 ms gap)
#
# The built-in WebSocket relay is a zero-cost substitute for TURN — media routes
# through our own server just like TURN would, but without external credentials or
# per-minute billing.
#
# To change the default STUN servers (e.g. use your own coturn in STUN mode):
# STUN_SERVERS=stun:your.stun.host:3478
# Default (6 servers from 3 independent providers — more servers = more NAT paths):
STUN_SERVERS=stun:stun.l.google.com:19302,stun:stun1.l.google.com:19302,stun:stun2.l.google.com:19302,stun:stun3.l.google.com:19302,stun:stun4.l.google.com:19302,stun:stun.cloudflare.com:3478

# ── Always-on connection (Gap 2 / Gap 6 fixes) ───────────────────────────────
# On server startup, write serverStartedAt to Firebase and send a "reconnect"
# Firebase command to every known device.  Devices detect the startup in < 3 s
# via Firebase push and call reconnectNow(), bypassing up-to-5-min Phase-2 backoff.
# Set to false only if Firebase Admin (serviceAccount.json) is not configured.
RECONNECT_ON_STARTUP=true

# Maximum number of devices to wake in one startup blast.
# Prevents Firebase quota exhaustion on very large deployments.
MAX_WAKE_DEVICES=50

# ── Metrics ───────────────────────────────────────────────────────────────────
# Ring-buffer size per device for /metrics/:id/history (max snapshots stored).
METRICS_HISTORY_SIZE=120
