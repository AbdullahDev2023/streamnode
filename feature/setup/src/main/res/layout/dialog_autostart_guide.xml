<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_guide_dialog"
    android:paddingBottom="0dp">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#22263A"
        android:paddingHorizontal="20dp"
        android:paddingVertical="16dp"
        android:gravity="center_vertical">
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="⚙️ Background Permission"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:fontFamily="sans-serif-medium"/>
        <TextView
            android:id="@+id/tvOemBadge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#6C63E6"
            android:textSize="12sp"
            android:paddingHorizontal="10dp"
            android:paddingVertical="4dp"
            android:background="@drawable/bg_status_badge"/>
    </LinearLayout>

    <!-- Why -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="StreamNode ko background mein chalane ke liye yeh permission ek baar deni hogi. Nahi di toh streaming automatically band ho jaayegi. 😟"
        android:textColor="#BBBBBB"
        android:textSize="13sp"
        android:lineSpacingMultiplier="1.4"
        android:paddingHorizontal="20dp"
        android:paddingTop="16dp"
        android:paddingBottom="8dp"/>

    <View android:layout_width="match_parent" android:layout_height="1dp"
        android:layout_marginHorizontal="20dp" android:layout_marginVertical="10dp"
        android:background="#2E3251"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Yeh steps follow karo:"
        android:textColor="#6C63E6"
        android:textSize="13sp"
        android:fontFamily="sans-serif-medium"
        android:paddingHorizontal="20dp"
        android:paddingBottom="10dp"/>

    <!-- Steps container — filled programmatically -->
    <LinearLayout
        android:id="@+id/llSteps"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="20dp"
        android:paddingBottom="8dp"/>

    <!-- Tip box -->
    <LinearLayout
        android:id="@+id/llTip"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginHorizontal="20dp"
        android:layout_marginBottom="16dp"
        android:layout_marginTop="4dp"
        android:background="@drawable/bg_tip_box"
        android:padding="12dp"
        android:gravity="top">
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="💡 " android:textSize="13sp"/>
        <TextView
            android:id="@+id/tvTip"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="#FFD166"
            android:textSize="12sp"
            android:lineSpacingMultiplier="1.4"/>
    </LinearLayout>

    <!-- Buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="20dp"
        android:paddingBottom="20dp"
        android:gravity="end">
        <TextView
            android:id="@+id/btnSkip"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Baad mein"
            android:textColor="#888888"
            android:textSize="14sp"
            android:paddingHorizontal="16dp"
            android:paddingVertical="10dp"
            android:clickable="true"
            android:focusable="true"/>
        <TextView
            android:id="@+id/btnOpenSettings"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Settings kholein →"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:fontFamily="sans-serif-medium"
            android:paddingHorizontal="20dp"
            android:paddingVertical="10dp"
            android:background="@drawable/bg_guide_btn"
            android:clickable="true"
            android:focusable="true"
            android:layout_marginStart="8dp"/>
    </LinearLayout>

</LinearLayout>
