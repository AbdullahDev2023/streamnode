<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark">

    <!-- App title -->
    <TextView
        android:id="@+id/tvSetupAppName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="StreamNode"
        android:textColor="@color/text_primary"
        android:textSize="24sp"
        android:fontFamily="sans-serif-medium"
        android:letterSpacing="0.06"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="48dp"/>

    <!-- Step dots -->
    <LinearLayout
        android:id="@+id/llStepDots"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        app:layout_constraintTop_toBottomOf="@id/tvSetupAppName"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="12dp">

        <View android:id="@+id/dot1"
            android:layout_width="8dp" android:layout_height="8dp"
            android:layout_marginHorizontal="4dp"
            android:background="@drawable/bg_step_number"/>
        <View android:id="@+id/dot2"
            android:layout_width="8dp" android:layout_height="8dp"
            android:layout_marginHorizontal="4dp"
            android:background="@drawable/bg_step_number"/>
        <View android:id="@+id/dot3"
            android:layout_width="8dp" android:layout_height="8dp"
            android:layout_marginHorizontal="4dp"
            android:background="@drawable/bg_step_number"/>
        <View android:id="@+id/dot4"
            android:layout_width="8dp" android:layout_height="8dp"
            android:layout_marginHorizontal="4dp"
            android:background="@drawable/bg_step_number"/>
    </LinearLayout>

    <!-- Step card -->
    <LinearLayout
        android:id="@+id/cardStep"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bg_guide_dialog"
        android:padding="28dp"
        android:gravity="center"
        app:layout_constraintTop_toBottomOf="@id/llStepDots"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintVertical_bias="0.38"
        android:layout_marginHorizontal="24dp">

        <TextView android:id="@+id/tvStepIcon"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="52sp"
            android:layout_marginBottom="16dp"/>

        <TextView android:id="@+id/tvStepTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/text_primary"
            android:textSize="18sp"
            android:fontFamily="sans-serif-medium"
            android:gravity="center"
            android:layout_marginBottom="12dp"/>

        <TextView android:id="@+id/tvStepDesc"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/text_secondary"
            android:textSize="14sp"
            android:gravity="center"
            android:lineSpacingMultiplier="1.5"
            android:layout_marginBottom="28dp"/>

        <!-- Primary action button -->
        <TextView android:id="@+id/btnStepAction"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/text_primary"
            android:textSize="15sp"
            android:fontFamily="sans-serif-medium"
            android:gravity="center"
            android:paddingVertical="14dp"
            android:background="@drawable/bg_guide_btn"
            android:clickable="true"
            android:focusable="true"/>

        <!-- Secondary (re-check) button — hidden by default -->
        <TextView android:id="@+id/btnStepSecondary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:visibility="gone"
            android:textColor="#888888"
            android:textSize="13sp"
            android:gravity="center"
            android:paddingVertical="12dp"
            android:layout_marginTop="8dp"
            android:clickable="true"
            android:focusable="true"/>

        <!-- Warning strip — shown after denial -->
        <LinearLayout android:id="@+id/llWarn"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:visibility="gone"
            android:background="@drawable/bg_tip_box"
            android:padding="12dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="16dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="⚠️ " android:textSize="14sp"/>
            <TextView android:id="@+id/tvWarn"
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="#FFD166" android:textSize="12sp"
                android:lineSpacingMultiplier="1.4"/>
        </LinearLayout>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
