<?xml version="1.0" encoding="utf-8"?>
<!--
    MainActivity layout — LOG CONSOLE ONLY.
    No buttons. No controls.
    Shows: app header · status badge · stream ID · scrolling live log.
-->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FF0F1117"
    tools:context=".ui.MainActivity">

    <!-- ── Header bar ── -->
    <LinearLayout
        android:id="@+id/llHeader"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="48dp"
        android:paddingBottom="12dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/tvAppName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="StreamNode"
            android:textColor="#FFFFFFFF"
            android:textSize="22sp"
            android:fontFamily="sans-serif-medium"
            android:letterSpacing="0.05" />

        <TextView
            android:id="@+id/tvStatusBadge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="● Idle"
            android:textColor="#88FFFFFF"
            android:textSize="12sp"
            android:paddingHorizontal="14dp"
            android:paddingVertical="5dp"
            android:background="@drawable/bg_status_badge" />

    </LinearLayout>

    <!-- ── Divider ── -->
    <View
        android:id="@+id/divider"
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:background="#1AFFFFFF"
        app:layout_constraintTop_toBottomOf="@id/llHeader"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />


    <!-- ── Stream ID ── -->
    <TextView
        android:id="@+id/tvStreamId"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Stream ID: …"
        android:textColor="#66FFFFFF"
        android:textSize="10sp"
        android:fontFamily="monospace"
        android:gravity="center"
        android:ellipsize="middle"
        android:singleLine="true"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        android:paddingHorizontal="20dp"
        app:layout_constraintTop_toBottomOf="@id/divider"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- ═══════════════════════════════════════════════════════════════════
         Phase 5 — Transport selector row
         Shows the live transport badge (updated by MainViewModel.transportMode)
         plus a compact 3-button RadioGroup for Auto / WebRTC P2P / WS Relay.
         The selected button is synced to SharedPreferences via MainViewModel.setTransport().
         ═══════════════════════════════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/llTransportRow"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="20dp"
        android:paddingTop="6dp"
        android:paddingBottom="2dp"
        app:layout_constraintTop_toBottomOf="@id/tvStreamId"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Live transport status badge (e.g. "⚡ WebRTC P2P") -->
        <TextView
            android:id="@+id/tvTransportStatus"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="🔄 Negotiating"
            android:textColor="#88FFFFFF"
            android:textSize="10sp"
            android:fontFamily="monospace"
            android:singleLine="true" />

        <!-- Transport pin selector: Auto | WebRTC | WS -->
        <RadioGroup
            android:id="@+id/rgTransport"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <RadioButton
                android:id="@+id/rbTransportAuto"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Auto"
                android:textColor="#AAFFFFFF"
                android:textSize="10sp"
                android:buttonTint="#FF6C63E6"
                android:paddingStart="4dp"
                android:paddingEnd="8dp" />

            <RadioButton
                android:id="@+id/rbTransportWebRtc"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⚡ P2P"
                android:textColor="#AAFFFFFF"
                android:textSize="10sp"
                android:buttonTint="#FF6C63E6"
                android:paddingStart="4dp"
                android:paddingEnd="8dp" />

            <RadioButton
                android:id="@+id/rbTransportWs"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📡 WS"
                android:textColor="#AAFFFFFF"
                android:textSize="10sp"
                android:buttonTint="#FF6C63E6"
                android:paddingStart="4dp"
                android:paddingEnd="0dp" />

        </RadioGroup>
    </LinearLayout>

    <!-- ── Log console label ── -->
    <TextView
        android:id="@+id/tvLogLabel"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="  LIVE LOG"
        android:textColor="#FF6C63E6"
        android:textSize="10sp"
        android:fontFamily="monospace"
        android:letterSpacing="0.12"
        android:paddingStart="20dp"
        android:paddingTop="6dp"
        android:paddingBottom="4dp"
        app:layout_constraintTop_toBottomOf="@id/llTransportRow"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- ── Thin accent line under label ── -->
    <View
        android:id="@+id/dividerLog"
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:background="#336C63E6"
        android:layout_marginHorizontal="20dp"
        app:layout_constraintTop_toBottomOf="@id/tvLogLabel"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />


    <!-- ── Scrolling log console — fills remaining space ── -->
    <ScrollView
        android:id="@+id/scrollLog"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:scrollbarStyle="outsideInset"
        android:scrollbarThumbVertical="@null"
        android:overScrollMode="never"
        android:paddingHorizontal="20dp"
        android:paddingBottom="24dp"
        android:clipToPadding="false"
        app:layout_constraintTop_toBottomOf="@id/dividerLog"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/tvLog"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="#CC00FF88"
            android:textSize="11sp"
            android:fontFamily="monospace"
            android:lineSpacingMultiplier="1.45"
            android:paddingTop="12dp"
            android:includeFontPadding="false"
            tools:text="[00:00:00.000]  🚀 Service started\n[00:00:00.100]  📡 Connecting…" />

    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
