# keystore.properties — local signing config (never commit this file)
# Copy this to keystore.properties and fill in your values.
# CI uses env vars (KEYSTORE_PATH, KEYSTORE_PASS, KEY_ALIAS, KEY_PASS) instead.

storeFile=../auracast-release.jks
storePassword=YOUR_KEYSTORE_PASSWORD
keyAlias=auracast
keyPassword=YOUR_KEY_PASSWORD
